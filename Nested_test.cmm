            out("*");
        }
        out("\n");
    }
    
    out("\n11.2 Number Spiral Pattern:\n");
    let size = 5;
    let spiral[5][5];
    let top = 0;
    let bottom = size - 1;
    let left = 0;
    let right = size - 1;
    let val = 1;
    
    for (let layer = 0; layer < (size + 1) / 2; layer++) {
        for (let i = left; i <= right; i++) {
            spiral[top][i] = val++;
        }
        top++;
        for (let i = top; i <= bottom; i++) {
            spiral[i][right] = val++;
        }
        right--;
        for (let i = right; i >= left; i--) {
            spiral[bottom][i] = val++;
        }
        bottom--;
        for (let i = bottom; i >= top; i--) {
            spiral[i][left] = val++;
        }
        left++;
    }
    
    for (let i = 0; i < size; i++) {
        for (let j = 0; j < size; j++) {
            out("%3d ", spiral[i][j]);
        }
