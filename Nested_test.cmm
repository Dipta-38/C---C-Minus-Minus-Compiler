        }
        out("\n");
    }
    
    out("\n9.2 Matrix addition:\n");
    for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) {
            matResult[i][j] = matA[i][j] + matB[i][j];
        }
    }
    
    out("  Result (A + B):\n");
    for (let i = 0; i < 4; i++) {
