    let stress_sum = 0;
    for (let stress_count = 1; stress_count <= 1000; stress_count++) {
        if: stress_count % 3 == 0 {
            stress_sum = stress_sum + stress_count;
        }
        elif: stress_count % 5 == 0 {
            stress_sum = stress_sum - stress_count;
        }
        elif: stress_count % 7 == 0 {
            stress_sum = stress_sum * 2 - stress_count;
        }
        else {
            stress_sum = stress_sum + stress_count % 10;
        }
        
        if: stress_count % 100 == 0 {
            out("  Iteration %d: sum = %d\n", stress_count, stress_sum);
        }
    }
