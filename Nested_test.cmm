    out("9.1 Initializing matrices:\n");
    for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) {
            matA[i][j] = i + j;
            matB[i][j] = i * j;
        }
    }
    
    out("  Matrix A:\n");
    for (let i = 0; i < 4; i++) {
        out("    ");
        for (let j = 0; j < 4; j++) {
